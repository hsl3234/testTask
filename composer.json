{
    "name": "testtask/phalcon-shop",
    "description": "Products & categories REST API (Phalcon + MySQL) with Volt + Vue 3 UI.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-phalcon": "^5.0",
        "phalcon/migrations": "^3.0",
        "zircote/swagger-php": "^4.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "scripts": {
        "migrate": "php vendor/bin/phalcon-migrations run --directory=."
    }
}
