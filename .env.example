APP_ENV=dev
APP_HOST_PORT=8080

DB_ROOT_PASSWORD=root
DB_NAME=shop
DB_USER=shop
DB_PASSWORD=shop
DB_HOST_PORT=3307

# Сидируемая админская учётка (миграция 1.0.1).
# В проде ОБЯЗАТЕЛЬНО задайте сильный пароль перед первым `docker compose up`.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

# TTL access/refresh-токенов в секундах (по умолчанию 15 мин / 14 дней).
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600
